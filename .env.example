# DomeCortex AI — environment variables reference.
# Copy the relevant subset into apps/backend/.env (backend) and
# apps/frontend/.env.local (frontend) for local development. Never commit a
# real .env file — only this example file with placeholder/empty values.

# --- Backend (apps/backend/.env) ---

# Postgres connection string (see docker-compose.yml for local dev defaults)
DATABASE_URL="postgresql://domecortex:domecortex@localhost:5432/domecortex?schema=public"

# Redis (BullMQ background workers)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# JWT (generate real random secrets for anything beyond local dev)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# MFA (two-factor authentication). MFA_ENCRYPTION_KEY must be a 32-byte key,
# hex-encoded (64 hex characters) — generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used to encrypt/decrypt each user's TOTP secret at rest (unlike a
# password, it must be reversible to generate/verify codes). A separate
# secret (not JWT_ACCESS_SECRET) signs the short-lived "MFA required, prove
# it" challenge token issued between password verification and the actual
# TOTP check, so that token can never be replayed as a real access token
# even if leaked.
MFA_ENCRYPTION_KEY=""
MFA_CHALLENGE_SECRET=""

# App
PORT="3001"
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# SMTP (optional — without it, emails are logged instead of sent, which is
# fine for local dev)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Where /contact form submissions are routed (optional — without it, they're
# logged instead of emailed, same "no fake data" pattern as everything else)
CONTACT_EMAIL=""

# Stripe (optional — without it, billing endpoints return a clear
# "not configured" error rather than fake checkout links)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_BUSINESS=""
# Optional annual-billing Price objects for the public pricing page's
# "Yearly" toggle — configure these to match the yearly amounts shown
# there (see PRICES in apps/frontend/lib/plans.ts) if you want to offer
# annual billing. Requesting a yearly checkout for a plan without one
# fails with a clear error rather than silently charging the monthly price.
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PROFESSIONAL_YEARLY=""
STRIPE_PRICE_BUSINESS_YEARLY=""

# Coinbase Commerce (optional — an additional, non-anonymous crypto payment
# method for the Starter/Professional plans. Every charge is still created
# for an already-authenticated, already-identified organization — see
# `apps/backend/src/billing/crypto-billing.service.ts` for why this
# product deliberately does not offer an anonymous/guest crypto checkout.
# Without a real API key, the crypto checkout endpoint returns a clear
# "not configured" error rather than a fake payment link.)
COINBASE_COMMERCE_API_KEY=""
COINBASE_COMMERCE_WEBHOOK_SECRET=""

# AI provider (optional — without a key, AI analysis endpoints return a
# clear "not configured" error rather than fake AI text). Two options:
#   - AI_PROVIDER=groq  + a free key from https://console.groq.com/keys
#     (no credit card, generous free tier, good enough to start with)
#   - AI_PROVIDER=anthropic (default) + a paid key from console.anthropic.com
AI_PROVIDER="anthropic"
AI_API_KEY=""

# Sentry error tracking/monitoring (optional — without it, errors are still
# logged via pino as before, just not reported anywhere else). Create a
# project at sentry.io (or a self-hosted instance) to get a real DSN.
SENTRY_DSN=""

# --- Frontend (apps/frontend/.env.local) ---

NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# The real public site URL — used to build sitemap.xml/robots.txt entries
# and absolute Open Graph/canonical-locale URLs. Falls back to
# http://localhost:3000 (honest for local/dev use) if unset; set this to
# the real production domain once one exists rather than leaving a fake
# placeholder domain baked in.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Sentry error tracking/monitoring (optional, same "inert until configured"
# pattern as the backend's SENTRY_DSN — can be a separate Sentry project from
# the backend's). DSNs are safe to expose client-side by design (not a
# secret), hence NEXT_PUBLIC_.
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed to upload readable source maps at build time (optional — the
# build silently skips this without a token rather than failing).
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
